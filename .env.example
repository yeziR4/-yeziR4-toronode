# ToroNode Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Server Configuration
PORT=3000
NODE_ENV=development

# Toronet SDK Configuration
# Network: 'testnet' or 'mainnet'
TORONET_NETWORK=testnet

# Override SDK base URL (SDK defaults are wrong — testnet → http://testnet.toronet.org = 404)
# Must point to the /api path, e.g. https://testnet.toronet.org/api
# TORONET_BASE_URL=https://testnet.toronet.org/api

# Admin Credentials (Required for fiat deposit endpoints)
# Register at https://payments.connectw.com to obtain these
# If not registered, deposit endpoints will return mock responses
ADMIN_WALLET_ADDRESS=
ADMIN_WALLET_PASSWORD=

# API Security
# Generate a strong random string for production
API_KEY=your-secure-api-key-here

# Logging
LOG_LEVEL=info